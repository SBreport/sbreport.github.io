{
  "manifest_version": 3,
  "name": "스마트 브랜딩 서포터",
  "short_name": "SBS",
  "version": "0.3.0",
  "description": "네이버 블로그/검색 분석을 위한 통합 도구. 글감 패널 숨기기, 검색 결과 네비게이터, 블로그 강조, 검색량 표시.",

  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://blog.naver.com/*",
    "https://m.blog.naver.com/*",
    "https://*.editor.naver.com/*",
    "https://search.naver.com/*",
    "https://naver-searchad-proxy.sbreport.workers.dev/*"
  ],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "스마트 브랜딩 서포터",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "https://blog.naver.com/*",
        "https://m.blog.naver.com/*",
        "https://*.editor.naver.com/*"
      ],
      "js": ["content/blog-cleaner.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://search.naver.com/*"
      ],
      "js": [
        "content/search-highlighter.js",
        "content/search-navigator.js",
        "content/search-volume.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
